# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_URL_LOCAL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_SECRET=your_secure_admin_secret_here

# ─── Encryption ───────────────────────────────────────────────────────────────
# Used to encrypt broker/exchange API keys before storing in the database.
# Must be at least 32 characters. Use a cryptographically random value.
#
# Generate with:
#   Node.js:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OpenSSL:  openssl rand -hex 32
#   Python:   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# CRITICAL:
#   - Never commit this value to version control
#   - Rotate carefully — changing this value makes ALL existing encrypted keys unreadable
#   - In production, inject via AWS Secrets Manager, Vercel env vars, or equivalent
ENCRYPTION_KEY=your_32_character_encryption_key_here

# ─── External APIs ────────────────────────────────────────────────────────────
# 실제 거래소 API 연동시 사용 (개발 단계에서는 비워둠)
KIS_API_KEY=
KIS_API_SECRET=
UPBIT_API_KEY=
UPBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Monitoring ───────────────────────────────────────────────────────────────
VERCEL_ANALYTICS_ID=
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true

# ─── Security ─────────────────────────────────────────────────────────────────
SESSION_MAX_AGE=86400
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# ─── Email ────────────────────────────────────────────────────────────────────
# Supabase에서 기본 제공하므로 선택사항
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
#   - Use a separate key per environment (dev / staging / prod)
ENCRYPTION_KEY=replace_with_64_char_hex_string_generated_above

# ─── AWS (optional — for Secrets Manager, S3 audit logs) ──────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2

# ─── Market API keys (all optional in dev — mock data used as fallback) ────────

# Korea Investment & Securities (한국투자증권)
# KIS_APP_KEY=
# KIS_APP_SECRET=

# Upbit (no key needed for public WebSocket — only needed for order placement)
# UPBIT_ACCESS_KEY=
# UPBIT_SECRET_KEY=

# Alpaca (US equities)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
